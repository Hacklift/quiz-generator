JWT_SECRET=replace-with-a-secure-random-value
JWT_ALGORITHM=HS256

EMAIL_SENDER=your-email@example.com
EMAIL_PASSWORD=replace-with-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

SHARE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MONGO_URI=mongodb://localhost:27017
DB_NAME=quizApp_db
FERNET_KEY=replace-with-a-generated-fernet-key
REDIS_URL=redis://localhost:6379/0

HUGGINGFACEHUB_API_TOKEN=hf_replace_with_your_token

# Optional overrides for document quiz generation.
# These defaults already exist in server/app/core/config.py, so only add them
# to a real .env file when you need non-default values.
# HF_QUIZ_MODEL=Qwen/Qwen2.5-7B-Instruct
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# DOCUMENT_UPLOAD_MAX_BYTES=10485760
# DOCUMENT_TEXT_MAX_CHARS=50000
# DOCUMENT_RAG_MAX_CHUNKS=24
# DOCUMENT_RAG_TOP_K=8
# DOCUMENT_CHUNK_SIZE_CHARS=1600
# DOCUMENT_CHUNK_OVERLAP_CHARS=220
# DOCUMENT_RAG_CACHE_ENABLED=true
